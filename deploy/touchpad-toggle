#!/usr/bin/env python3
"""Auto-disable touchpad when external mouse connected.
Usage:
  touchpad-toggle off      disable touchpad
  touchpad-toggle on       enable touchpad
  touchpad-toggle status   show current state

Tries (in order):
  1. xinput (XWayland — works on niri, sway, hyprland, any compositor
     with XWayland running)
  2. swaymsg (sway/hyprland native IPC)
  3. evtest daemon (holds EVIOCGRAB — kernel-level, no XWayland needed)

Install: sudo cp deploy/touchpad-toggle /usr/local/bin/touchpad-toggle
"""
import subprocess, sys, os, signal, re

def find_xinput_id():
    """Return XInput device ID for the touchpad, or None."""
    try:
        out = subprocess.check_output(
            ['xinput', 'list'], text=True, timeout=3,
            stderr=subprocess.DEVNULL
        )
    except Exception:
        return None
    for line in out.splitlines():
        if 'touchpad' in line.lower():
            m = re.search(r'id=(\d+)', line)
            if m:
                return m.group(1)
    return None

def toggle_xinput(enable):
    """Toggle touchpad via xinput (works with XWayland)."""
    dev_id = find_xinput_id()
    if not dev_id:
        return False
    cmd = ['xinput', 'enable' if enable else 'disable', dev_id]
    try:
        subprocess.run(cmd, timeout=3, check=True,
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        print(f'touchpad-toggle: xinput {"enabled" if enable else "disabled"}',
              file=sys.stderr)
        return True
    except Exception:
        return False

def try_swaymsg(enable):
    try:
        import json
        val = 'enabled' if enable else 'disabled'
        out = subprocess.check_output(
            ['swaymsg', '-t', 'get_inputs'], text=True, timeout=3,
            stderr=subprocess.DEVNULL
        )
        for inp in json.loads(out):
            if inp.get('type') == 'touchpad':
                name = inp['identifier']
                subprocess.run(
                    ['swaymsg', f'input "{name}" events {val}'],
                    timeout=3, stdout=subprocess.DEVNULL
                )
        print(f'touchpad-toggle: swaymsg {val}', file=sys.stderr)
        return True
    except Exception:
        return False

def find_touchpad_evdev():
    for ent in sorted(os.listdir('/sys/class/input/')):
        if not ent.startswith('event'):
            continue
        try:
            with open(f'/sys/class/input/{ent}/device/name') as f:
                if 'touchpad' in f.read().lower():
                    return f'/dev/input/{ent}'
        except Exception:
            continue
    return None

def daemon_spawn():
    tp = find_touchpad_evdev()
    if not tp:
        return 0
    pid = os.fork()
    if pid > 0:
        return pid
    os.setsid()
    pid2 = os.fork()
    if pid2 > 0:
        os._exit(0)
    try:
        import fcntl
        fd = os.open(tp, os.O_RDWR)
        fcntl.ioctl(fd, 0x40044590, 1)
        with open('/tmp/touchpad-grab.pid', 'w') as f:
            f.write(str(os.getpid()))
        signal.pause()
    except Exception:
        pass
    os._exit(0)

def daemon_kill():
    try:
        with open('/tmp/touchpad-grab.pid') as f:
            pid = int(f.read().strip())
        os.kill(pid, signal.SIGTERM)
        try:
            os.waitpid(pid, 0)
        except Exception:
            pass
    except FileNotFoundError:
        return False
    except ProcessLookupError:
        pass
    try:
        os.remove('/tmp/touchpad-grab.pid')
    except Exception:
        pass
    return True

def daemon_running():
    try:
        with open('/tmp/touchpad-grab.pid') as f:
            os.kill(int(f.read().strip()), 0)
        return True
    except Exception:
        return False

def main():
    cmd = sys.argv[1] if len(sys.argv) > 1 else 'status'

    if cmd == 'status':
        tp = find_touchpad_evdev()
        xid = find_xinput_id()
        print(f'  touchpad evdev:  {tp or "NOT FOUND"}')
        print(f'  touchpad xinput: {xid or "NOT FOUND"}')
        print(f'  daemon running:  {daemon_running()}')
        return

    if cmd == 'on':
        if toggle_xinput(True):
            return
        if try_swaymsg(True):
            return
        daemon_kill()
        print('touchpad-toggle: re-enabled', file=sys.stderr)
        return

    if cmd == 'off':
        if toggle_xinput(False):
            return
        if try_swaymsg(False):
            return
        if daemon_running():
            print('touchpad-toggle: already off', file=sys.stderr)
            return
        pid = daemon_spawn()
        if pid > 0:
            print(f'touchpad-toggle: disabled (daemon PID={pid})', file=sys.stderr)
        else:
            print('touchpad-toggle: no method worked', file=sys.stderr)
            sys.exit(1)

if __name__ == '__main__':
    main()
